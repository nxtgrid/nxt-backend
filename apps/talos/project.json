{
  "name": "talos",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/talos/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "sourceMap": true,
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/talos",
        "main": "apps/talos/src/main.ts",
        "tsConfig": "apps/talos/tsconfig.app.json",
        "isolatedConfig": true,
        "webpackConfig": "apps/talos/webpack.config.js",
        "assets": [
          {
            "glob": "**/*.sql",
            "input": "apps/talos/src/queries/",
            "output": "queries/"
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "talos:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "talos:build:development"
        },
        "production": {
          "buildTarget": "talos:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/talos/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/talos/jest.config.ts",
        "coverage": true
      }
    }
  },
  "tags": []
}
