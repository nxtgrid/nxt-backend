  "scripts": {
    "check-types": "tsc -p tsconfig.base.json --noEmit --allowSyntheticDefaultImports",
    "eslint": "eslint . --ext .ts",
    "eslint:fix": "eslint . --ext .ts --fix",
    "lint": "npm run eslint && npm run check-types",
    "prepare": "husky",
    "fix-node-cpu": "npm rebuild fsevents",
    "build:tiamat": "nx build tiamat",
    "preinstall": "npx npm-force-resolutions",
    "build:loch": "nx build loch",
    "build:yeti": "nx build yeti",
    "gen-types-remote": "npx supabase@latest gen types typescript --project-id axenumkepgnwfmdogkqq > supabase/generated-types.ts",
    "gen-types-local": "npx supabase@latest gen types typescript --local > supabase/generated-types.ts",
    "gen-better-types": "npx better-supabase-types -i supabase/generated-types.ts -o libs/core/src/types/supabase-types.ts -s --enumAsType && node .scripts/fix-supabase-json-type.js && eslint --fix libs/core/src/types/supabase-types.ts && rm supabase/generated-types.ts",
    "generate-types": "npm run gen-types-remote && npm run gen-better-types",
    "generate-types:local": "npm run gen-types-local && npm run gen-better-types"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
